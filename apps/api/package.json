{
  "name": "@sac/api",
  "version": "1.0.0",
  "private": "true",
  "scripts": {
    "env:load": "dotenv -e ../../.env --",
    "dev": "npm run env:load tsx watch src/http/server.ts",
    "db:migrate": "npm run env:load prisma migrate dev",
    "db:studio": "npm run env:load prisma studio",
    "db:seed": "npm run env:load prisma db push --force-reset && npx prisma db seed",
    "build": "tsup",
    "start": "node dist/http/server.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@prisma/client": "^5.15.0",
    "@sac/authorization": "*",
    "@sac/env": "*",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "fastify-type-provider-zod": "^1.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@sac/eslint": "*",
    "@sac/prettier": "*",
    "@sac/tsconfig": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.2",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.15.0",
    "tsup": "^8.3.5",
    "tsx": "^4.15.4"
  },
  "prettier": "@sac/prettier",
  "eslintConfig": {
    "extends": [
      "@sac/eslint/node"
    ]
  }
}
